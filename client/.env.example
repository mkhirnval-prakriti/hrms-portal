# Vite env (optional). Copy to client/.env for local overrides.

# Empty = same origin as the page (recommended for Replit / single-server deploy).
# Example external API: VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Dev only: Express port for Vite proxy (default 5000)
VITE_API_PORT=5000
