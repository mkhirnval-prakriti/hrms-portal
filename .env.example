# Copy to `.env` — never commit `.env`.

# Server
PORT=5000
NODE_ENV=development
HOST=0.0.0.0

# Secrets — required for NODE_ENV=production
SESSION_SECRET=
JWT_SECRET=

# SQLite (default ./data/hrms.sqlite)
DB_PATH=

# --- CORS (optional; same-origin SPA needs no CORS) ---
# Comma-separated list: https://app.example.com,https://admin.example.com
# Leave empty: only same-origin browser requests (no CORS headers).
# * = allow any origin (not recommended with credentials).
ALLOWED_ORIGINS=
# Set to 1 to disable auto-added localhost:5173 / :5000 in development
CORS_STRICT=

# --- Static SPA (after `npm run build`) ---
# Vite writes to dist/app/ by default. Override only if you change the build path.
# STATIC_APP_DIR=

# Docs only — browser uses same host by default
API_BASE_URL=
