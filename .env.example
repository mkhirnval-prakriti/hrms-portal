# Copy to .env locally. On Render, set these in the Web Service → Environment.

# --- Server ---
NODE_ENV=production
PORT=3000

# Strong random string (sessions + cookie signing)
SESSION_SECRET=

# Optional: separate key for encrypting Google OAuth tokens in SQLite (falls back to SESSION_SECRET)
INTEGRATION_SECRET=

# --- SQLite database ---
# Default: ./data/hrms.sqlite (relative to project root)
# On Render with a persistent disk mounted at e.g. /data, use:
# DB_PATH=/data/hrms.sqlite
DB_PATH=

# --- Seed passwords (first deploy / empty DB only) ---
# SEED_ADMIN_PASSWORD=
# SEED_DEMO_PASSWORD=

# --- Google OAuth (Sheets sync from Settings UI) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Production redirect (must match Google Cloud OAuth client):
# GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-RENDER-SERVICE.onrender.com/api/integrations/google/oauth/callback

# --- Google Sheets (service account, optional alternative to OAuth) ---
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Or split:
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Google Apps Script Web App (dynamic row push) ---
# GOOGLE_APPS_SCRIPT_WEBAPP_URL=https://script.google.com/macros/s/.../exec
# APPS_SCRIPT_SYNC_ENABLED=1
# APPS_SCRIPT_FORCE_TEST=0

# --- Ops ---
# RENDER=1
