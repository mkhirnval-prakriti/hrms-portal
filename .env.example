# =============================================================================
# Prakriti Herbs HRMS — copy to `.env` locally. Never commit `.env`.
# On Render: Web Service → Environment (generate secrets in dashboard).
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=3000
# Listen address (0.0.0.0 required for Replit, Docker, cloud)
HOST=0.0.0.0

# Session cookies (required in production)
SESSION_SECRET=

# JWT (Authorization: Bearer); use a long random string in production
JWT_SECRET=

# Optional: encrypt Google OAuth tokens at rest (falls back to SESSION_SECRET)
INTEGRATION_SECRET=

# SQLite path (default: ./data/hrms.sqlite). On Render with disk: /data/hrms.sqlite
DB_PATH=

# Set on Render hosted services (optional; used for logging)
RENDER=1

# --- Seed (empty DB / first boot only) ---
SEED_ADMIN_PASSWORD=
SEED_DEMO_PASSWORD=

# --- Google OAuth (Sheets UI — Settings → Integrations) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match OAuth client redirect URI, e.g.:
# GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-SERVICE.onrender.com/api/integrations/google/oauth/callback

# --- Google Sheets (spreadsheet ID fallback) ---
GOOGLE_SHEETS_SPREADSHEET_ID=

# --- Google service account (alternative to OAuth) ---
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- Google Apps Script (dynamic push) ---
GOOGLE_APPS_SCRIPT_WEBAPP_URL=
APPS_SCRIPT_SYNC_ENABLED=1
APPS_SCRIPT_FORCE_TEST=0

# --- Health (no auth) ---
# GET /health  GET /api/health
