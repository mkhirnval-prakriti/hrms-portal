# Copy to `.env` for local overrides — optional; the server auto-generates missing secrets.

# --- Defaults (applied in code when unset) ---
# DATABASE_URL defaults to: file:./data/hrms.sqlite
# SESSION_SECRET / JWT_SECRET: if empty, read from SQLite integration_kv or generated once and stored (stable across restarts)
# SEED_ADMIN_PASSWORD: auto-generated on first empty DB; stored in SQLite for stable logins

NODE_ENV=production
PORT=
HOST=0.0.0.0

SESSION_SECRET=
JWT_SECRET=

DATABASE_URL=file:./data/hrms.sqlite
DB_PATH=

SEED_ADMIN_PASSWORD=
SEED_DEMO_PASSWORD=
SUPER_ADMIN_EMAIL=

STATIC_APP_DIR=
ALLOWED_ORIGINS=
CORS_STRICT=
API_BASE_URL=
GOOGLE_APPS_SCRIPT_WEBAPP_URL=

# WebAuthn (passkeys) for attendance — HTTPS + matching hostname required in production.
# WEBAUTHN_RP_ID must equal the site hostname (e.g. app.example.com, not https://).
# WEBAUTHN_ORIGINS is comma-separated full origins (e.g. https://app.example.com,http://localhost:5173).
# WEBAUTHN_ATTENDANCE: off | after_register | required
#   off: no passkey check on punch.
#   after_register: if the user has at least one passkey, each self punch must include a valid assertion.
#   required: user must register a passkey before punching; then assertion required.
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGINS=
WEBAUTHN_RP_NAME=
WEBAUTHN_ATTENDANCE=after_register

# Face embedding match (L2 distance) when user_face_profiles.embedding_json is set. Lower = stricter.
FACE_EMBEDDING_MATCH_THRESHOLD=0.55

# Minimum days between completed/rejected/expired/cancelled biometric update requests (same kind: face or passkey).
BIOMETRIC_UPDATE_COOLDOWN_DAYS=14
# Hours the employee has to complete enrollment after a manager approves.
BIOMETRIC_APPROVAL_WINDOW_HOURS=24

TRASH_RETENTION_MODE=days
TRASH_RETENTION_DAYS=30
TRASH_RETENTION_MINUTES=30
