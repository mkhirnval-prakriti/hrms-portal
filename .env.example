# Copy to `.env` — never commit `.env`.

# Server
PORT=5000
NODE_ENV=development
HOST=0.0.0.0

# Secrets — required for NODE_ENV=production
SESSION_SECRET=
JWT_SECRET=

# SQLite — use either DB_PATH (file path) or DATABASE_URL (e.g. file:./data/hrms.sqlite)
DB_PATH=
DATABASE_URL=

# --- CORS (optional; same-origin SPA needs no CORS) ---
# Comma-separated list: https://app.example.com,https://admin.example.com
# Leave empty: only same-origin browser requests (no CORS headers).
# * = allow any origin (not recommended with credentials).
ALLOWED_ORIGINS=
# Set to 1 to disable auto-added localhost:5173 / :5000 in development
CORS_STRICT=

# --- Static SPA (after `npm run build`) ---
# Vite writes to dist/app/ by default. Override only if you change the build path.
# STATIC_APP_DIR=

# Docs only — browser uses same host by default
API_BASE_URL=

# Optional: Google Apps Script outbound sync (leave unset to skip)
GOOGLE_APPS_SCRIPT_WEBAPP_URL=

# Trash retention policy for soft-deleted staff
# mode: "days" (default) or "minutes"
TRASH_RETENTION_MODE=days
TRASH_RETENTION_DAYS=30
TRASH_RETENTION_MINUTES=30
