# HRMS — Replit Deploy
# Secrets: SESSION_SECRET, JWT_SECRET (see .env.example). Replit injects PORT.
language = "nodejs"
run = "npm run start"
entrypoint = "server.js"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "npm install && npm run build && npm run start"]
build = ["sh", "-c", "npm install && npm run build"]
